class CAsyncWait: public CActive
{

public:
    CAsyncWait():CActive(CActive::EPriorityStandard)
    {
	iWait = new (ELeave) CActiveSchedulerWait;
	CActiveScheduler::Add(this);
    }
    virtual ~CAsyncWait()
    {
	Cancel();
	delete iWait;
    }
    /*CAsyncWaiter()
    {
    }*/
    void ActivatedL()
    {

	SetActive();
    }
    TInt Start()
    {
	SetActive();
	iWait->Start();
	return iStatus.Int();
    }
    void RunL()
    {
	_LIT(msg, "RunL");
	ErrorNoteL(&msg);
	iWait->AsyncStop();
    }
    void DoCancel(){}

private:
    CActiveSchedulerWait* iWait;
};


#include <etel3rdparty.h>

static TInt getPhoneIMEIL(TDes &aDes)
{

#ifdef __WINS__
  // copied from PyS60 sysinfomodule
  // Return a fake IMEI when on emulator 
  _LIT(KEmulatorIMEI, "000000000000000");
  return KEmulatorIMEI;

#else
  CTelephony::TPhoneIdV1 phoneId;    
  CTelephony::TPhoneIdV1Pckg phoneIdPkg(phoneId);
  CTelephony* tel = CTelephony::NewL();
  CAsyncWait* aWait = new CAsyncWait;
  
  TRequestStatus status = aWait->iStatus;
  tel->GetPhoneId(status, phoneIdPkg);
  TInt err = aWait->Start();
  if (!err) aDes.Copy(phoneId.iSerialNumber);

  delete aWait;
  delete tel;
  //CleanupStack::PopAndDestroy(tel);  
  return status.Int();

#endif /*__WINS__*/
}


