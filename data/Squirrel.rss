RESOURCE FORM r_generator_settings_form
{
    flags = EEikFormEditModeOnly|EEikFormUseDoubleSpacedFormat;
    items = 
    {
        DLG_LINE
        {
	    type = EEikCtNumberEditor;
            prompt = qtn_generatorsettings_item1_string;
            id = EGeneratorSettingsItem1;
            itemflags = EEikDlgItemTakesEnterKey | EEikDlgItemOfferAllHotKeys;
	    control = NUMBER_EDITOR
            {
		min = 1;
		max = 40;
	    };
	},
        DLG_LINE
        {
            type = EEikCtNumberEditor;
            prompt = qtn_generatorsettings_item2_string;
            id = EGeneratorSettingsItem2;
            itemflags = EEikDlgItemTakesEnterKey | EEikDlgItemOfferAllHotKeys;
            control = NUMBER_EDITOR
            {
		min = 1;
		max = 40;
	    };
	},
        DLG_LINE
        {
            type = EAknCtPopupFieldText;
            prompt = qtn_generatorsettings_item3_string;
            id = EGeneratorSettingsItem3;
            itemflags = EEikDlgItemTakesEnterKey | EEikDlgItemOfferAllHotKeys;
            control = POPUP_FIELD_TEXT
                {
                popupfield = POPUP_FIELD
                    {
                    width = 100;
                    };
                textarray = r_ecl_textarray;
                active = 3;    
                };
	},
        DLG_LINE
        {
            type = EEikCtNumberEditor;
            prompt = qtn_generatorsettings_item4_string;
            id = EGeneratorSettingsItem4;
            itemflags = EEikDlgItemTakesEnterKey | EEikDlgItemOfferAllHotKeys;
            control = NUMBER_EDITOR
            {
		min = 1;
		max = 640;
	    };
	},
        DLG_LINE
        {
            type = EEikCtNumberEditor;
            prompt = qtn_generatorsettings_item5_string;
            id = EGeneratorSettingsItem5;
            itemflags = EEikDlgItemTakesEnterKey | EEikDlgItemOfferAllHotKeys;
            control = NUMBER_EDITOR
            {
		min = 1;
		max = 10;
	    };
	},
        DLG_LINE
        {
            type = EAknCtPopupFieldText;
            prompt = qtn_generatorsettings_item6_string;
            id = EGeneratorSettingsItem6;
            itemflags = EEikDlgItemTakesEnterKey | EEikDlgItemOfferAllHotKeys;
            control = POPUP_FIELD_TEXT
                {
                popupfield = POPUP_FIELD
                    {
                    width = 100;
                    };
                textarray = r_imageformats_textarray;
                active = 0;    
                };
	},
        DLG_LINE
        {
            type = EEikCtEdwin;
            prompt = qtn_generatorsettings_item7_string;
            id = EGeneratorSettingsItem7;
            itemflags = EEikDlgItemTakesEnterKey;
            control = EDWIN
                {
		    maxlength=8;
                };
	},
        DLG_LINE
        {
            type = EEikCtEdwin;
            prompt = qtn_generatorsettings_item8_string;
            id = EGeneratorSettingsItem8;
            itemflags = EEikDlgItemTakesEnterKey;
            control = EDWIN
                {
		    maxlength=8;
                };
	}
    };
}

RESOURCE ARRAY r_ecl_textarray
{
    items =
